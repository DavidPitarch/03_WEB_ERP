# Copy this file to .env.test and fill in your test credentials.
# These are consumed by the global-setup and backoffice spec files.

# URL of the running backoffice dev server (default: http://localhost:5173)
TEST_BACKOFFICE_URL=http://localhost:5173

# URL of the running operator PWA dev server (default: http://localhost:5174)
TEST_OPERATOR_URL=http://localhost:5174

# Backoffice user credentials (needed to save auth session for tests 2-4).
# If not set, auth-dependent tests are automatically skipped.
TEST_BACKOFFICE_EMAIL=admin@yourdomain.com
TEST_BACKOFFICE_PASSWORD=your_password_here
