# Copia este fichero a .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.

# ── Supabase (requerido) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# ── URL del edge API ──────────────────────────────────────────────────────────
# En dev local: dejar vacío. Vite hace proxy automático /api → localhost:8787.
# En CF Pages / demo: poner la URL completa del worker SIN barra final.
#   Ej: https://erp-siniestros-api-demo.<account>.workers.dev
VITE_API_URL=
